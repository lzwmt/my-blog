{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": false,
    "jsx": "react-jsx",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "types": ["react", "react-dom", "node"],
    "incremental": true,
    "tsBuildInfoFile": "./node_modules/.cache/admin.typecheck.tsbuildinfo"
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "config/**/*.ts"],
  "exclude": ["node_modules", "src/.umi", "src/.umi-production", "dist"]
}
